# ============================================================
# NUTROPACT AUDIT FRAMEWORK — ENVIRONMENT CONFIGURATION
# Copy to .env and fill in values before running
# ============================================================

# --- Target ---
BASE_URL=https://oopsie-woopsie-code.lovable.app
ADMIN_URL=https://oopsie-woopsie-code.lovable.app/admin

# --- Admin credentials ---
ADMIN_EMAIL=info@nutropact.com
ADMIN_PASSWORD=@Wings2mrelimo

# --- Customer credentials (existing account for auth tests) ---
CUSTOMER_EMAIL=info@nutropact.com
CUSTOMER_PASSWORD=@Wings2mrelimo

# --- Fresh accounts for signup tests (use disposable email service) ---
TEST_EMAIL_PREFIX=nutropact-audit-test
TEST_EMAIL_DOMAIN=mailinator.com

# --- Supabase (if direct DB verification is needed) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Reporting ---
REPORT_DIR=./reports/output
SCREENSHOTS_DIR=./reports/output/screenshots
VIDEOS_DIR=./reports/output/videos

# --- Timeouts (ms) ---
DEFAULT_TIMEOUT=15000
NAVIGATION_TIMEOUT=30000
API_TIMEOUT=10000

# --- Headless mode ---
HEADLESS=false
SLOW_MO=0

# ──────────────────────────────────────────────────────────────────────────
# NutroPact — Self-host environment template
# Copy to .env.local and fill in. NEVER commit .env.local.
# ──────────────────────────────────────────────────────────────────────────

# ====== Supabase (apni project se le — supabase.com → Settings → API) ======
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-public-key>
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# Server-only (TanStack server functions use these — NEVER prefix with VITE_)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-SECRET>
SUPABASE_PROJECT_ID=<your-project-ref>

# ====== Backend (your Node/Express API) ======
VITE_API_BASE_URL=https://api.yourdomain.com
ADMIN_API_TOKEN=<random-long-string>

# ====== Payments ======
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=

# ====== Communications ======
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ====== AI ======
OPENAI_API_KEY=

# ====== Shipping / Logistics ======
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ====== Analytics / Pixels ======
VITE_GA_MEASUREMENT_ID=
VITE_FB_PIXEL_ID=

# ====== Misc ======
SESSION_SECRET=<random-32-char-string>
WEBHOOK_SECRET=<random-32-char-string>